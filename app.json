{
  "expo": {
    "name": "Diplometr",
    "slug": "diplometr",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "diplometr",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": { "supportsTablet": true },
    "android": { "adaptiveIcon": { "backgroundColor": "#ffffff" } },
    "web": { "bundler": "metro", "output": "single" },
    "plugins": ["expo-router"],
    "extra": {
      "apiBaseUrl": "http://localhost:4000"
    }
  }
}
